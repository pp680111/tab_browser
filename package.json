{
  "name": "guitar-tabs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:app": "concurrently -k \"vite --host 127.0.0.1 --port 3000\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "npm run dev:app",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@coderline/alphatab": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@coderline/alphatab-vite": "^1.8.2",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^37.2.3",
    "electron-builder": "^26.0.12",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  }
}
